# ── Xenios website — environment variables ───────────────────────────────────
# Copy this file to .env and fill in real values for LOCAL development only.
# In Replit, set these in the Secrets pane (Tools → Secrets), NOT in a committed file.
# NEVER commit real secrets. This file must contain blank/example values only.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project URL and public anon key are safe for the browser.
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key is SERVER-ONLY. Never expose it to the frontend, logs, or git.
SUPABASE_SERVICE_ROLE_KEY=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Analytics (Meta Pixel) ───────────────────────────────────────────────────
META_PIXEL_ID=

# ── Booking (Calendly) ───────────────────────────────────────────────────────
CALENDLY_WEBHOOK_SECRET=

# ── Bot protection (Cloudflare Turnstile) ────────────────────────────────────
# Site key is public (used in the browser); secret key is SERVER-ONLY.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Application config (non-secret) ──────────────────────────────────────────
ADMIN_EMAIL=samuel@xeniostechnology.com
FROM_EMAIL=team@xeniostechnology.com
REPLY_TO_EMAIL=team@xeniostechnology.com
SITE_URL=https://xeniostechnology.com

# ── xenios research (all optional; the section fails closed without the password) ──
# Password for the gated /research section. REQUIRED for the section to serve at all.
RESEARCH_ACCESS_PASSWORD=
# Optional dedicated cookie-signing secret (defaults to a hash derived from the password).
RESEARCH_SESSION_SECRET=
# Commerce stays OFF unless explicitly "true". Enable only after processor, supplier,
# quality, legal, and state review.
NEXT_PUBLIC_RESEARCH_COMMERCE_ENABLED=false
NEXT_PUBLIC_CONSUMER_COMMERCE_ENABLED=false
# Order dispatch webhook (Quantum fulfillment adapter). No orders are accepted without it.
ORDER_WEBHOOK_URL=
ORDER_WEBHOOK_SECRET=
# Set to "true" only when the section is cleared for indexing (default: noindex).
RESEARCH_INDEXABLE=false

# ── xenios research membership (Phase 4/5) ──
# Launch switch: "true" opens the public research experience without the review
# password (default: private, password-gated).
RESEARCH_PUBLIC=false
# Days an approval remains activatable before it expires.
RESEARCH_APPROVAL_EXPIRY_DAYS=14
# Membership activation fee (Phase 5, Stripe). One-time by default; configuration
# only, no recurring billing is exposed.
RESEARCH_MEMBERSHIP_PRICE_CENTS=5000
RESEARCH_MEMBERSHIP_BILLING_MODE=one_time
RESEARCH_MEMBERSHIP_CURRENCY=usd
# Stripe (Phase 5). Absent = activation shows a branded setup-pending state.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_RESEARCH_MEMBERSHIP_PRICE_ID=
